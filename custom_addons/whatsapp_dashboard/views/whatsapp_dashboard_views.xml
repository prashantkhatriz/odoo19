<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<data>

    <!-- Client action — loads the OWL component by its registry tag -->
    <record id="action_whatsapp_dashboard" model="ir.actions.client">
        <field name="name">WhatsApp Dashboard</field>
        <field name="tag">whatsapp_dashboard</field>
        <field name="target">current</field>
    </record>

    <!-- Top-level app entry in Odoo's native sidebar -->
    <menuitem
        id="menu_whatsapp_root"
        name="WhatsApp"
        sequence="200"
    />

    <menuitem
        id="menu_whatsapp_dashboard"
        name="WhatsApp Dashboard"
        parent="menu_whatsapp_root"
        action="action_whatsapp_dashboard"
        sequence="1"
    />

</data>
</odoo>