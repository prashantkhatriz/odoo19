<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="whatsapp_dashboard.WhatsAppDashboard" owl="1">
<div class="wa-root">

    <!-- ═══════════════════════════════════════════════════════════════
         ODOO PURPLE SIDEBAR
    ═══════════════════════════════════════════════════════════════ -->
    <div class="wa-odoo-sidebar" t-att-class="{ 'wa-odoo-sidebar--collapsed': state.sidebarCollapsed }">
        <div class="wa-odoo-sidebar-inner">

            <!-- Header: odoo logo + brand -->
            <div class="wa-odoo-header">
                <button class="wa-odoo-logo-btn" title="New">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <line x1="7" y1="1" x2="7" y2="13" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        <line x1="1" y1="7" x2="13" y2="7" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </button>
                <span class="wa-odoo-brand">odoo</span>
            </div>

            <!-- Nav items -->
            <nav class="wa-odoo-nav">
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'dashboard' }"
                    t-on-click="() => this.setNavItem('dashboard')"
                    data-label="Dashboard">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="3" y="3" width="7" height="7" rx="1"/>
                            <rect x="14" y="3" width="7" height="7" rx="1"/>
                            <rect x="3" y="14" width="7" height="7" rx="1"/>
                            <rect x="14" y="14" width="7" height="7" rx="1"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Dashboard</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'crm' }"
                    t-on-click="() => this.setNavItem('crm')"
                    data-label="CRM">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">CRM</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'sales' }"
                    t-on-click="() => this.setNavItem('sales')"
                    data-label="Sales">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                            <polyline points="17 6 23 6 23 12"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Sales</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'inventory' }"
                    t-on-click="() => this.setNavItem('inventory')"
                    data-label="Inventory">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                            <line x1="12" y1="22.08" x2="12" y2="12"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Inventory</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'purchase' }"
                    t-on-click="() => this.setNavItem('purchase')"
                    data-label="Purchase">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="9" cy="21" r="1"/>
                            <circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Purchase</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'accounting' }"
                    t-on-click="() => this.setNavItem('accounting')"
                    data-label="Accounting">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Accounting</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'project' }"
                    t-on-click="() => this.setNavItem('project')"
                    data-label="Project">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <line x1="8" y1="6" x2="21" y2="6"/>
                            <line x1="8" y1="12" x2="21" y2="12"/>
                            <line x1="8" y1="18" x2="21" y2="18"/>
                            <line x1="3" y1="6" x2="3.01" y2="6"/>
                            <line x1="3" y1="12" x2="3.01" y2="12"/>
                            <line x1="3" y1="18" x2="3.01" y2="18"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Project</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'employees' }"
                    t-on-click="() => this.setNavItem('employees')"
                    data-label="Employees">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Employees</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'apps' }"
                    t-on-click="() => this.setNavItem('apps')"
                    data-label="Apps">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="3" y="3" width="5" height="5" rx="1"/>
                            <rect x="10" y="3" width="5" height="5" rx="1"/>
                            <rect x="17" y="3" width="5" height="5" rx="1"/>
                            <rect x="3" y="10" width="5" height="5" rx="1"/>
                            <rect x="10" y="10" width="5" height="5" rx="1"/>
                            <rect x="17" y="10" width="5" height="5" rx="1"/>
                            <rect x="3" y="17" width="5" height="5" rx="1"/>
                            <rect x="10" y="17" width="5" height="5" rx="1"/>
                            <rect x="17" y="17" width="5" height="5" rx="1"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Apps</span>
                </button>
                <button class="wa-odoo-nav-item"
                    t-att-class="{ 'wa-odoo-nav-item--active': state.activeNavItem === 'settings' }"
                    t-on-click="() => this.setNavItem('settings')"
                    data-label="Settings">
                    <span class="wa-odoo-nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                    </span>
                    <span class="wa-odoo-nav-label">Settings</span>
                </button>
            </nav>
        </div>

        <!-- Collapse toggle button -->
        <button class="wa-odoo-toggle" t-on-click="toggleSidebar" title="Toggle sidebar">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M6.5 1.5L3 5l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         MAIN CONTENT — your existing dashboard
    ═══════════════════════════════════════════════════════════════ -->
    <div class="wa-odoo-main">

        <!-- MODULE HEADER -->
        <div class="wa-module-header">

            <div class="wa-module-header-left">
                <!-- WhatsApp icon -->
                <div class="wa-header-logo">
                    <svg viewBox="0 0 32 32" width="32" height="32">
                        <circle cx="16" cy="16" r="16" fill="#25D366"/>
                        <path fill="#fff" d="M16 5.3C10.1 5.3 5.3 10.1 5.3 16c0 1.9.5 3.7 1.4 5.2L5.3 26.7l5.7-1.4c1.5.8 3.2 1.3 5 1.3 5.9 0 10.7-4.8 10.7-10.7S21.9 5.3 16 5.3zm5.7 15c-.2.7-1.4 1.3-1.9 1.3-.5 0-.9.2-3.4-.7-2.8-1.2-4.7-4-4.8-4.2-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.3-.3.6-.4.8-.4h.5c.2 0 .4-.1.6.5.2.6.8 2 .9 2.1.1.1.1.3 0 .5-.1.2-.1.3-.3.5-.1.2-.3.4-.4.5-.1.1-.3.3-.1.6.2.3.7 1.2 1.6 2 1.1 1 2 1.3 2.3 1.4.3.1.4.1.6-.1.2-.2.7-.8.9-1.1.2-.3.4-.2.6-.1.2.1 1.6.8 1.9.9.3.1.5.2.5.3.1.1.1.7-.1 1.3z"/>
                    </svg>
                </div>
                <span class="wa-module-title">WhatsApp</span>
            </div>

            <div class="wa-module-header-right">
                <!-- Connected indicator -->
                <span class="wa-connected-dot"/>
                <span class="wa-connected-label">Connected</span>

                <!-- Configuration button -->
                <button class="wa-config-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    Configuration
                </button>

                <!-- Overflow menu -->
                <button class="wa-icon-btn" title="More options">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <circle cx="12" cy="5"  r="2"/>
                        <circle cx="12" cy="12" r="2"/>
                        <circle cx="12" cy="19" r="2"/>
                    </svg>
                </button>
            </div>

        </div>
        <!-- end module header -->


        <!-- BODY: sidebar + chat -->
        <div class="wa-body">

            <!-- CHAT SIDEBAR (thread list) -->
            <div class="wa-sidebar">

                <!-- Search input row -->
                <div class="wa-search-row">
                    <div class="wa-search-wrap">
                        <svg class="wa-search-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input class="wa-search-input"
                            type="text"
                            placeholder="Search or start new chat"
                            t-model="state.searchQuery"/>
                    </div>
                    <button class="wa-icon-btn" title="Filter options">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="4"  y1="6"  x2="20" y2="6"/>
                            <line x1="8"  y1="12" x2="16" y2="12"/>
                            <line x1="11" y1="18" x2="13" y2="18"/>
                        </svg>
                    </button>
                </div>

                <!-- Filter pills -->
                <div class="wa-filter-row">
                    <t t-foreach="['All', 'External', 'Internal Notes']" t-as="tab" t-key="tab">
                        <button class="wa-filter-pill"
                            t-att-class="{ 'wa-filter-pill--active': state.activeFilter === tab }"
                            t-on-click="() => this.setFilter(tab)">
                            <t t-esc="tab"/>
                        </button>
                    </t>
                </div>

                <!-- Thread rows -->
                <div class="wa-thread-list">
                    <t t-if="filteredThreads.length === 0">
                        <div class="wa-no-threads">No conversations found</div>
                    </t>
                    <t t-foreach="filteredThreads" t-as="thread" t-key="thread.id">
                        <div class="wa-thread-item"
                            t-att-class="{ 'wa-thread-item--active': state.activeThread and state.activeThread.id === thread.id }"
                            t-on-click="() => this.selectThread(thread)">

                            <!-- Avatar with initials + online dot -->
                            <div class="wa-avatar" t-att-style="'background:' + thread.color">
                                <t t-esc="thread.initials"/>
                                <span class="wa-avatar-dot"
                                    t-att-class="thread.status === 'online' ? 'wa-avatar-dot--on' : ''"/>
                            </div>

                            <!-- Thread info -->
                            <div class="wa-thread-info">
                                <div class="wa-thread-row1">
                                    <span class="wa-thread-name"><t t-esc="thread.name"/></span>
                                    <span class="wa-thread-time"
                                        t-att-class="thread.unread > 0 ? 'wa-thread-time--green' : ''">
                                        <t t-esc="thread.time"/>
                                    </span>
                                </div>
                                <div class="wa-thread-row2">
                                    <span class="wa-thread-preview"><t t-esc="thread.last_message"/></span>
                                    <t t-if="thread.unread > 0">
                                        <span class="wa-badge"><t t-esc="thread.unread"/></span>
                                    </t>
                                </div>
                            </div>

                        </div>
                    </t>
                </div>
                <!-- end thread list -->

            </div>
            <!-- end left panel -->


            <!-- CHAT AREA -->
            <div class="wa-chat">

                <!-- Empty state -->
                <t t-if="!state.activeThread">
                    <div class="wa-empty">
                        <div class="wa-empty-ring">
                            <svg width="56" height="56" viewBox="0 0 32 32">
                                <circle cx="16" cy="16" r="16" fill="#25D366"/>
                                <path fill="#fff" d="M16 5.3C10.1 5.3 5.3 10.1 5.3 16c0 1.9.5 3.7 1.4 5.2L5.3 26.7l5.7-1.4c1.5.8 3.2 1.3 5 1.3 5.9 0 10.7-4.8 10.7-10.7S21.9 5.3 16 5.3z"/>
                            </svg>
                        </div>
                        <h2 class="wa-empty-title">WhatsApp Dashboard</h2>
                        <p class="wa-empty-sub">
                            Select a conversation to start messaging.
                            Messages are sent via Twilio WhatsApp.
                        </p>
                    </div>
                </t>

                <!-- Active thread -->
                <t t-if="state.activeThread">

                    <!-- Chat header -->
                    <div class="wa-chat-header">

                        <div class="wa-chat-header-left" t-on-click="openInfoPanel" title="View contact info">
                            <div class="wa-avatar" t-att-style="'background:' + state.activeThread.color">
                                <t t-esc="state.activeThread.initials"/>
                                <span class="wa-avatar-dot"
                                    t-att-class="state.activeThread.status === 'online' ? 'wa-avatar-dot--on' : ''"/>
                            </div>
                            <div class="wa-chat-contact-info">
                                <span class="wa-contact-name"><t t-esc="state.activeThread.name"/></span>
                                <span class="wa-contact-status"
                                    t-att-class="state.activeThread.status === 'online' ? 'wa-contact-status--online' : ''">
                                    <t t-if="state.activeThread.status === 'online'">Online</t>
                                    <t t-else="">last seen recently</t>
                                </span>
                            </div>
                        </div>

                        <div class="wa-chat-header-right">
                            <!-- Video call -->
                            <button class="wa-icon-btn wa-icon-btn--lg" title="Video call" t-on-click="startVideoCall">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <polygon points="23 7 16 12 23 17 23 7"/>
                                    <rect x="1" y="5" width="15" height="14" rx="2"/>
                                </svg>
                            </button>
                            <!-- Voice call -->
                            <button class="wa-icon-btn wa-icon-btn--lg" title="Voice call" t-on-click="startVoiceCall">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.48 2 2 0 0 1 3.59 1.3h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                            </button>
                            <!-- Search in chat -->
                            <button class="wa-icon-btn wa-icon-btn--lg" title="Search">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <circle cx="11" cy="11" r="8"/>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                </svg>
                            </button>
                            <!-- Contact info -->
                            <button class="wa-icon-btn wa-icon-btn--lg" title="Contact info" t-on-click="openInfoPanel">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                            </button>
                            <!-- Overflow -->
                            <button class="wa-icon-btn wa-icon-btn--lg" title="More options">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <circle cx="12" cy="5"  r="2"/>
                                    <circle cx="12" cy="12" r="2"/>
                                    <circle cx="12" cy="19" r="2"/>
                                </svg>
                            </button>
                        </div>

                    </div>
                    <!-- end chat header -->


                    <!-- Messages feed -->
                    <div class="wa-messages" t-ref="messages">

                        <div class="wa-date-chip"><span>Today</span></div>

                        <t t-foreach="state.messages" t-as="msg" t-key="msg.id">
                            <div class="wa-msg-row"
                                t-att-class="msg.direction === 'outgoing' ? 'wa-msg-row--out' : 'wa-msg-row--in'">
                                <div class="wa-bubble"
                                    t-att-class="{
                                        'wa-bubble--out':      msg.direction === 'outgoing',
                                        'wa-bubble--in':       msg.direction === 'incoming',
                                        'wa-bubble--internal': msg.type === 'internal'
                                    }">
                                    <span class="wa-bubble-text"><t t-esc="msg.body"/></span>
                                    <span class="wa-bubble-footer">
                                        <span class="wa-bubble-time"><t t-esc="msg.time"/></span>
                                        <!-- Double-tick for outgoing -->
                                        <t t-if="msg.direction === 'outgoing'">
                                            <span class="wa-ticks"
                                                t-att-class="msg.status === 'read' ? 'wa-ticks--blue' : ''">
                                                <svg width="15" height="11" viewBox="0 0 15 11" fill="none">
                                                    <path d="M1 5.5L4.5 9 8 4.5"   stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M7 5.5L10.5 9 14 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </span>
                                        </t>
                                    </span>
                                </div>
                            </div>
                        </t>

                        <!-- Typing indicator -->
                        <t t-if="state.isTyping">
                            <div class="wa-msg-row wa-msg-row--in">
                                <div class="wa-bubble wa-bubble--in wa-typing">
                                    <span class="wa-dot"/>
                                    <span class="wa-dot"/>
                                    <span class="wa-dot"/>
                                </div>
                            </div>
                        </t>

                    </div>
                    <!-- end messages -->


                    <!-- Attachment menu (floats above input bar) -->
                    <t t-if="state.showAttachMenu">
                        <div class="wa-attachment-menu">
                            <div class="wa-attachment-item" t-on-click="() => this.handleAttachment('document')">
                                <span class="wa-attachment-icon">📄</span>
                                <span class="wa-attachment-label">Document</span>
                            </div>
                            <div class="wa-attachment-item" t-on-click="() => this.handleAttachment('photos')">
                                <span class="wa-attachment-icon">🖼</span>
                                <span class="wa-attachment-label">Photos &amp; Videos</span>
                            </div>
                        </div>
                    </t>


                    <!-- Input bar -->
                    <div class="wa-input-bar">

                        <!-- Paperclip / attach -->
                        <button class="wa-icon-btn wa-icon-btn--lg" title="Attach file" t-on-click="toggleAttachMenu">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8696a0" stroke-width="2">
                                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                            </svg>
                        </button>

                        <!-- Emoji -->
                        <button class="wa-icon-btn wa-icon-btn--lg" title="Emoji">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8696a0" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                                <line x1="9"  y1="9"  x2="9.01"  y2="9"/>
                                <line x1="15" y1="9"  x2="15.01" y2="9"/>
                            </svg>
                        </button>

                        <!-- Internal note badge -->
                        <t t-if="state.msgType === 'internal'">
                            <span class="wa-internal-badge">Internal Note</span>
                        </t>

                        <!-- Text input -->
                        <input class="wa-input-field"
                            t-att-class="{ 'wa-input-field--internal': state.msgType === 'internal' }"
                            type="text"
                            t-att-placeholder="state.msgType === 'internal' ? 'Write an internal note...' : 'Type a message'"
                            t-model="state.draftMessage"
                            t-on-keydown="onKeyDown"/>

                        <!-- Note toggle -->
                        <button class="wa-note-toggle"
                            t-att-class="{ 'wa-note-toggle--active': state.msgType === 'internal' }"
                            title="Toggle internal note"
                            t-on-click="toggleMsgType">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </button>

                        <!-- Send button -->
                        <button class="wa-send-btn"
                            t-att-class="{ 'wa-send-btn--active': state.draftMessage.trim().length > 0 }"
                            title="Send"
                            t-on-click="sendMessage">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                                <line x1="22" y1="2" x2="11" y2="13"/>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </button>

                    </div>
                    <!-- end input bar -->


                    <!-- Contact info panel (slides in from right) -->
                    <t t-if="state.showInfoPanel">
                        <div class="wa-info-panel">

                            <div class="wa-info-header">
                                <button class="wa-icon-btn" t-on-click="closeInfoPanel" title="Close">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6"  x2="6"  y2="18"/>
                                        <line x1="6"  y1="6"  x2="18" y2="18"/>
                                    </svg>
                                </button>
                                Contact Info
                            </div>

                            <div class="wa-info-avatar" t-att-style="'background:' + state.activeThread.color">
                                <t t-esc="state.activeThread.initials"/>
                            </div>
                            <div class="wa-info-name"><t t-esc="state.activeThread.name"/></div>
                            <div class="wa-info-phone"><t t-esc="state.activeThread.phone"/></div>

                            <div class="wa-info-section">
                                <div class="wa-info-section-title">About</div>
                                <div style="font-size:14px;color:var(--wa-text-muted);">
                                    Available for business enquiries.
                                </div>
                            </div>

                            <div class="wa-info-section">
                                <div class="wa-info-section-title">Privacy &amp; Security</div>
                                <div class="wa-info-row">
                                    <span>Disappearing messages</span>
                                    <button class="wa-info-toggle" title="Toggle disappearing messages"/>
                                </div>
                                <div class="wa-info-row">
                                    <span>Advanced chat privacy</span>
                                    <button class="wa-info-toggle" title="Toggle advanced privacy"/>
                                </div>
                                <div class="wa-info-encrypt">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="11" width="18" height="11" rx="2"/>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                    </svg>
                                    Messages are end-to-end encrypted
                                </div>
                            </div>

                            <div class="wa-info-section">
                                <div class="wa-info-section-title">Media, Links and Docs</div>
                                <div style="font-size:13px;color:var(--wa-text-muted);padding:4px 0;">
                                    No media shared yet.
                                </div>
                            </div>

                            <div class="wa-info-actions">
                                <button class="wa-info-action-btn wa-info-action-btn--danger">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M10 11v6M14 11v6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                    Clear Chat
                                </button>
                                <button class="wa-info-action-btn wa-info-action-btn--danger">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                                    </svg>
                                    Delete Chat
                                </button>
                            </div>

                        </div>
                    </t>
                    <!-- end info panel -->

                </t>
                <!-- end active thread -->

            </div>
            <!-- end chat area -->

        </div>
        <!-- end wa-body -->

    </div>
    <!-- end wa-odoo-main -->


    <!-- ═══════════════════════════════════════════════════════════════
         VOICE CALL MODAL
    ═══════════════════════════════════════════════════════════════ -->
    <t t-if="state.showVoiceCall">
        <div class="wa-call-overlay" t-on-click.self="endCall">
            <div class="wa-call-card">

                <div class="wa-call-avatar"
                    t-att-style="'background:' + (state.activeThread ? state.activeThread.color : '#25D366')">
                    <t t-esc="state.activeThread ? state.activeThread.initials : ''"/>
                </div>

                <div class="wa-call-name">
                    <t t-esc="state.activeThread ? state.activeThread.name : ''"/>
                </div>
                <div class="wa-call-status"><t t-esc="state.callStatus"/></div>

                <t t-if="state.callConnected">
                    <div class="wa-call-timer"><t t-esc="state.callTimer"/></div>
                </t>

                <div class="wa-call-actions">
                    <button class="wa-call-btn wa-call-btn--grey"
                        t-att-class="{ 'wa-call-btn--active': state.isMuted }"
                        title="Mute" t-on-click="toggleMute">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                            <line x1="12" y1="19" x2="12" y2="23"/>
                            <line x1="8"  y1="23" x2="16" y2="23"/>
                        </svg>
                    </button>
                    <button class="wa-call-btn wa-call-btn--red" title="End call" t-on-click="endCall">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                            <path d="M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.42 19.42 0 0 1 4.68 12 19.79 19.79 0 0 1 1.61 3.48a2 2 0 0 1 1.98-2.18H6.6a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11z" transform="rotate(135 12 12)"/>
                        </svg>
                    </button>
                    <button class="wa-call-btn wa-call-btn--grey"
                        t-att-class="{ 'wa-call-btn--active': state.speakerOn }"
                        title="Speaker" t-on-click="toggleSpeaker">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                        </svg>
                    </button>
                </div>

            </div>
        </div>
    </t>


    <!-- ═══════════════════════════════════════════════════════════════
         VIDEO CALL MODAL
    ═══════════════════════════════════════════════════════════════ -->
    <t t-if="state.showVideoCall">
        <div class="wa-video-overlay">

            <div class="wa-video-main">
                <div class="wa-video-avatar"
                    t-att-style="'background:' + (state.activeThread ? state.activeThread.color : '#25D366')">
                    <t t-esc="state.activeThread ? state.activeThread.initials : ''"/>
                </div>
                <div class="wa-video-name">
                    <t t-esc="state.activeThread ? state.activeThread.name : ''"/>
                </div>
                <div class="wa-video-status"><t t-esc="state.callStatus"/></div>
                <t t-if="state.callConnected">
                    <div class="wa-video-timer"><t t-esc="state.callTimer"/></div>
                </t>
            </div>

            <div class="wa-video-pip">
                <div class="wa-video-pip-inner">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
            </div>

            <div class="wa-video-controls">
                <button class="wa-call-btn wa-call-btn--dark"
                    t-att-class="{ 'wa-call-btn--active': state.isMuted }"
                    title="Mute" t-on-click="toggleMute">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    </svg>
                </button>
                <button class="wa-call-btn wa-call-btn--dark"
                    t-att-class="{ 'wa-call-btn--active': state.cameraOff }"
                    title="Camera" t-on-click="toggleCamera">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="23 7 16 12 23 17 23 7"/>
                        <rect x="1" y="5" width="15" height="14" rx="2"/>
                    </svg>
                </button>
                <button class="wa-call-btn wa-call-btn--red" title="End call" t-on-click="endCall">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                        <path d="M10.68 13.31a16 16 0 0 0 3.41 2.6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.42 19.42 0 0 1 4.68 12 19.79 19.79 0 0 1 1.61 3.48a2 2 0 0 1 1.98-2.18H6.6a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11z" transform="rotate(135 12 12)"/>
                    </svg>
                </button>
                <button class="wa-call-btn wa-call-btn--dark" title="Screenshot">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                        <circle cx="12" cy="13" r="4"/>
                    </svg>
                </button>
                <button class="wa-call-btn wa-call-btn--dark" title="Fullscreen">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
                    </svg>
                </button>
            </div>

        </div>
    </t>

</div>
</t>
</templates>